---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
      title="USYD iA Presnter Template"
      img="/iA.jpg"
      desc="Template for iA Presenter, a software to quickly create aesthetically pleasing presentation slides,
      in the style of the University of Sydney"
      url="https://github.com/herbertwxin/USYD-iA-Templatey"
      badge="NEW"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Fiscal Theory on Disinflation"
    img="/dynare.jpg"
    desc="Study the effect of a fiscal-led disinflation."
    url="https://github.com/herbertwxin/Disinflation-Fiscal-Theory"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Marcoeconomics with Manim"
    img="/Manim.png"
    desc="Creating macroeconomics courses with Manim."
    url="https://www.youtube.com/channel/UC-yDi0dCtK-pceROXmp5pyg"
  />

